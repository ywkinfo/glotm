{
  "name": "glotm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "content:latam": "tsx LatTm/scripts/build-master.ts && tsx LatTm/scripts/qa-content.ts && tsx LatTm/scripts/build-content.ts",
    "content:mexico": "tsx MexTm/scripts/qa-content.ts && tsx MexTm/scripts/build-content.ts",
    "content:usa": "tsx UsaTm/scripts/build-content.ts",
    "content:japan": "tsx JapTm/scripts/build-content.ts",
    "content:china": "tsx ChaTm/scripts/build-content.ts",
    "content:europe": "tsx EuTm/scripts/build-content.ts",
    "content:prepare": "npm run content:latam && npm run content:mexico && npm run content:usa && npm run content:japan && npm run content:china && npm run content:europe",
    "predev": "npm run content:prepare",
    "dev": "vite",
    "prebuild": "npm run content:prepare",
    "build": "tsc -b && vite build",
    "build:pages": "npm run build && node scripts/prepare-pages.mjs",
    "build:pages:glotm": "PAGES_BASE_PATH=/GloTm/ npm run build:pages",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "minisearch": "^7.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "github-slugger": "^2.0.0",
    "jsdom": "^27.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
