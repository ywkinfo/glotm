{
  "name": "glotm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "content:latam": "tsx LatTm/scripts/build-master.ts && tsx LatTm/scripts/qa-content.ts && tsx LatTm/scripts/build-content.ts",
    "content:mexico": "tsx MexTm/scripts/build-content.ts",
    "content:prepare": "npm run content:latam && npm run content:mexico",
    "predev": "npm run content:prepare",
    "dev": "vite",
    "prebuild": "npm run content:prepare",
    "build": "tsc -b && vite build",
    "build:pages": "npm run build && node scripts/prepare-pages.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "minisearch": "^7.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "github-slugger": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^6.3.5"
  }
}
